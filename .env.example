# Backend secrets (CollegeConnect) - do not commit; this file is the template
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=collegeconnect
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-adminsdk.json
GOOGLE_APPLICATION_CREDENTIALS=firebase-adminsdk.json
GOOGLE_IMPERSONATE_USER=admin@your-workspace.com
# Resend API key for booking emails
RESEND_API_KEY=re_YOUR_KEY
RESEND_FROM="CollegeConnect <bookings@yourdomain.com>"

# Alternatively, pass the full JSON content of your firebase-adminsdk.json here:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", ...}'

# AWS S3 - ID storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=collegeconnect-id-storage
S3_COLLEGE_IDS_PREFIX=college-ids
S3_TEMP_COLLEGE_IDS_PREFIX=college-ids-temp
S3_PROFILE_PICTURES_PREFIX=profile-pictures
SIGNUP_TEMP_UPLOAD_TTL_MINUTES=30

# PhonePe — https://dashboard.phonepe.com/ (merchants)
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT
BASE_URL=http://localhost:5173
# Optional local dev CORS overrides (include all Vite fallback ports you use)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
