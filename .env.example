# Backend secrets (CollegeConnect) - do not commit; this file is the template
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=collegeconnect
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-adminsdk.json
GOOGLE_APPLICATION_CREDENTIALS=firebase-adminsdk.json
GOOGLE_IMPERSONATE_USER=admin@your-workspace.com
# Resend API key for booking emails
RESEND_API_KEY=re_YOUR_KEY
RESEND_FROM="CollegeConnect <bookings@yourdomain.com>"
